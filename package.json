{
  "name": "austrian-currents",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "pages:dev": "wrangler pages dev --proxy 5173",
    "dev:full": "concurrently -n vite,wrangler -c cyan,yellow \"npm run dev\" \"npm run pages:dev\"",
    "deploy": "npm run build && wrangler pages deploy dist"
  },
  "dependencies": {
    "@deck.gl/mapbox": "^9.3.5",
    "deck.gl": "^9.3.5",
    "fast-xml-parser": "^5.9.3",
    "maplibre-gl": "^5.24.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260626.1",
    "@types/geojson": "^7946.0.16",
    "concurrently": "^10.0.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "wrangler": "^4.105.0"
  }
}
